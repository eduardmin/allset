option_settings:
  # Force Elastic Beanstalk to use a Launch Template instead of the retired
  # EC2 Launch Configurations (AWS stopped allowing launch configs on Oct 1, 2024).
  # Setting any one of these options triggers the migration; we set a few that are
  # also good hygiene (gp3 root volume, larger disk, IMDSv2-only).
  aws:autoscaling:launchconfiguration:
    RootVolumeType: gp3
    RootVolumeSize: "24"
    DisableIMDSv1: true
